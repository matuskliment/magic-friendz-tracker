rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function authEmailLower() {
      return isSignedIn() && request.auth.token.email != null
        ? request.auth.token.email.lower()
        : '';
    }

    function isGlobalAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function groupDoc(groupId) {
      return get(/databases/$(database)/documents/groups/$(groupId));
    }

    function memberPath(groupId) {
      return /databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid);
    }

    function isMember(groupId) {
      return isSignedIn() && exists(memberPath(groupId));
    }

    function memberRole(groupId) {
      return get(memberPath(groupId)).data.role;
    }

    function isEditor(groupId) {
      return isMember(groupId) && memberRole(groupId) in ['editor', 'owner'];
    }

    function isOwnerMember(groupId) {
      return isMember(groupId) && memberRole(groupId) == 'owner';
    }

    // Owner on the group document (legacy / admin-set) even if members/{uid} is missing
    function isGroupOwnerDoc(groupId) {
      return isSignedIn()
        && (
          groupDoc(groupId).data.ownerUid == request.auth.uid
          || (
            authEmailLower() != ''
            && groupDoc(groupId).data.ownerEmail == authEmailLower()
          )
        );
    }

    function canManageGroup(groupId) {
      return isGlobalAdmin() || isEditor(groupId) || isGroupOwnerDoc(groupId);
    }

    function canDeleteMatches(groupId) {
      return isGlobalAdmin() || isOwnerMember(groupId) || isGroupOwnerDoc(groupId);
    }

    function hasInvite(groupId) {
      return isSignedIn()
        && authEmailLower() != ''
        && exists(/databases/$(database)/documents/groups/$(groupId)/memberEmails/$(authEmailLower()));
    }

    function canClaimOwner(groupId) {
      return isSignedIn()
        && groupDoc(groupId).data.ownerUid == request.auth.uid;
    }

    function canClaimOwnerByEmail(groupId) {
      return isSignedIn()
        && authEmailLower() != ''
        && groupDoc(groupId).data.ownerEmail == authEmailLower();
    }

    match /admins/{uid} {
      allow read: if isSignedIn() && request.auth.uid == uid;
      allow write: if false;
    }

    match /groups/{groupId} {
      allow get: if true;
      allow list: if isGlobalAdmin()
        || (isSignedIn() && (
          resource.data.ownerUid == request.auth.uid
          || (authEmailLower() != '' && resource.data.ownerEmail == authEmailLower())
        ));
      allow create: if isSignedIn()
        && request.resource.data.ownerUid == request.auth.uid;
      allow update: if canManageGroup(groupId);
      allow delete: if canDeleteMatches(groupId);

      match /members/{uid} {
        // Broad read for signed-in users (debug: verify collectionGroup access).
        allow read: if isSignedIn();
        allow create: if isGlobalAdmin()
          || (isSignedIn()
            && request.auth.uid == uid
            && request.resource.data.role == 'editor'
            && hasInvite(groupId))
          || (isSignedIn()
            && request.auth.uid == uid
            && request.resource.data.role == 'owner'
            && (canClaimOwner(groupId) || canClaimOwnerByEmail(groupId)))
          || (isOwnerMember(groupId)
            && request.auth.uid == uid
            && request.resource.data.role == 'owner');
        allow update: if isGlobalAdmin() || isOwnerMember(groupId) || isGroupOwnerDoc(groupId);
        allow delete: if isGlobalAdmin() || isOwnerMember(groupId) || isGroupOwnerDoc(groupId);
      }

      match /memberEmails/{emailId} {
        // Broad read for signed-in users (debug: verify collectionGroup access).
        allow read: if isSignedIn();
        allow create, update, delete: if canManageGroup(groupId);
      }

      match /matches/{matchId} {
        allow read: if true;
        allow create, update: if canManageGroup(groupId);
        allow delete: if canDeleteMatches(groupId);
      }

      match /roster/{rosterId} {
        // Broad read for signed-in users (debug: verify collectionGroup access).
        allow read: if isSignedIn();
        allow create, update, delete: if canManageGroup(groupId);
      }

      match /settings/{docId} {
        allow read: if true;
        allow write: if canManageGroup(groupId);
      }
    }
  }
}